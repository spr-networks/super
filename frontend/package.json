      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "preset": "react-native",
    "moduleDirectories": [
      "src",
      "node_modules"
    ],
    "setupFilesAfterEnv": [
      "./src/setupTests.js"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(@react-native|react-native|react-router-native|@react-native-community/push-notification-ios|@gluestack-ui|@expo|@legendapp)/).*/"
    ],
    "globals": {
      "__DEV__": true
    },
    "moduleNameMapper": {
      "^@react-native-clipboard/clipboard$": "<rootDir>/node_modules/@react-native-clipboard/clipboard/jest/clipboard-mock.js",
