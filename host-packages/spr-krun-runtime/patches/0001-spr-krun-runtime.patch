+/* libkrun's guest init receives limits through KRUN_RLIMITS; it does not
+ * parse process.rlimits from .krun_config.json. Forward the ordinary OCI
+ * process setting explicitly so Compose ulimits work inside the microVM. */
+static int
+libkrun_configure_rlimits (uint32_t ctx_id, void *handle, runtime_spec_schema_config_schema *def, libcrun_error_t *err)
+{
+  __typeof__ (krun_set_rlimits) *set_rlimits;
+  char **guest_rlimits;
+  size_t limits_len;
+  int ret = 0;
+
+  if (def == NULL || def->process == NULL || def->process->rlimits_len == 0)
+    return 0;
+
+  set_rlimits = dlsym (handle, "krun_set_rlimits");
+  if (set_rlimits == NULL)
+    return crun_make_error (err, 0, "could not find symbol `krun_set_rlimits` in the krun library");
