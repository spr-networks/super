+static int
+libkrun_run_ip (char **argv, const char *operation, libcrun_error_t *err)
+{
+  int ret;
+
+  ret = run_process (argv, err);
+  if (UNLIKELY (ret < 0))
+    return ret;
+  if (UNLIKELY (ret != 0))
+    return crun_make_error (err, EINVAL, "%s failed with exit status %d", operation, ret);
+
+  return 0;
+}
