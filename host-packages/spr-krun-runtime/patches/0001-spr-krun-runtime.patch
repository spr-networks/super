+static bool
+libkrun_valid_policy_token (const char *token)
+{
+  if (token == NULL || strlen (token) != 64)
+    return false;
+  for (size_t i = 0; i < 64; i++)
+    if (! ((token[i] >= '0' && token[i] <= '9') || (token[i] >= 'a' && token[i] <= 'f')))
+      return false;
+  return true;
+}
+
+/* The policy token is an untrusted bearer reference.  Privileged values live
+ * only in the referenced root-owned file; raw krun.* OCI annotations and the
+ * image-controlled /.krun_vm.json are deliberately ignored. */
+static int
+libkrun_read_trusted_policy (struct krun_config *kconf, libcrun_container_t *container, libcrun_error_t *err)
+{
+  cleanup_close int varfd = -1;
+  cleanup_close int libfd = -1;
+  cleanup_close int rootfd = -1;
+  cleanup_close int policyfd = -1;
+  cleanup_close int fd = -1;
+  cleanup_free char *filename = NULL;
+  cleanup_free char *config = NULL;
+  struct stat st;
+  const char *token;
+  int ret;
+
+  token = find_annotation (container, SPR_KRUN_POLICY_ANNOTATION);
+  if (token == NULL)
+    return 0;
+  if (! libkrun_valid_policy_token (token))
+    return crun_make_error (err, EINVAL, "invalid SPR krun policy token");
+
+  varfd = open (SPR_KRUN_VAR_DIR, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (varfd < 0)
+    return crun_make_error (err, errno, "open trusted krun policy parent");
+  ret = libkrun_check_trusted_directory (varfd, SPR_KRUN_VAR_DIR, S_IWGRP | S_IWOTH, err);
+  if (ret < 0)
+    return ret;
+
+  libfd = openat (varfd, "lib", O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (libfd < 0)
+    return crun_make_error (err, errno, "open trusted krun policy library directory");
+  ret = libkrun_check_trusted_directory (libfd, SPR_KRUN_VAR_LIB_DIR, S_IWGRP | S_IWOTH, err);
+  if (ret < 0)
+    return ret;
+
+  rootfd = openat (libfd, "spr-krun", O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (rootfd < 0)
+    return crun_make_error (err, errno, "open trusted krun policy root");
+  ret = libkrun_check_trusted_directory (rootfd, SPR_KRUN_POLICY_ROOT, S_IRWXG | S_IRWXO, err);
+  if (ret < 0)
+    return ret;
+
+  policyfd = openat (rootfd, "policies", O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (policyfd < 0)
+    return crun_make_error (err, errno, "open trusted krun policy directory");
+  ret = libkrun_check_trusted_directory (policyfd, SPR_KRUN_POLICY_DIR, S_IRWXG | S_IRWXO, err);
+  if (ret < 0)
+    return ret;
+
+  xasprintf (&filename, "%s.json", token);
+  fd = openat (policyfd, filename, O_RDONLY | O_CLOEXEC | O_NOFOLLOW);
+  if (fd < 0)
+    return crun_make_error (err, errno, "open manager-issued krun policy");
+  if (fstat (fd, &st) < 0)
+    return crun_make_error (err, errno, "inspect manager-issued krun policy");
+  if (! S_ISREG (st.st_mode) || st.st_uid != 0 || (st.st_mode & (S_IRWXG | S_IRWXO)) != 0)
+    return crun_make_error (err, EPERM, "manager-issued krun policy is not a private root-owned regular file");
+
   ret = read_all_fd (fd, "krun configuration file", &config, NULL, err);
   if (UNLIKELY (ret < 0))
