+static bool
+libkrun_has_network_namespace (runtime_spec_schema_config_schema *def)
+{
+  size_t i;
+
+  if (def == NULL || def->linux == NULL)
+    return false;
+
+  for (i = 0; i < def->linux->namespaces_len; i++)
+    if (def->linux->namespaces[i] != NULL && def->linux->namespaces[i]->type != NULL
+        && strcmp (def->linux->namespaces[i]->type, "network") == 0)
+      return true;
+
+  return false;
+}
