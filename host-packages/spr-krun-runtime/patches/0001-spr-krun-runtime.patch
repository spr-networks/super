+/* Validate a vsock endpoint relative to an opened, trusted directory.  The
+ * directory is the allowlist: only root can place host services in it. */
+static int
+libkrun_validate_vsock_path (const char *path, bool listen, libcrun_error_t *err)
+{
+  cleanup_close int runfd = -1;
+  cleanup_close int rootfd = -1;
+  cleanup_close int dirfd = -1;
+  struct stat run_st;
+  struct stat root_st;
+  struct stat dir_st;
+  struct stat socket_st;
+  const char *directory;
+  const char *directory_name;
+  const char *prefix;
+  const char *name;
+  int ret;
+
+  directory = listen ? SPR_KRUN_LISTEN_DIR : SPR_KRUN_CONNECT_DIR;
+  directory_name = listen ? "listen" : "connect";
+  prefix = listen ? SPR_KRUN_LISTEN_DIR "/" : SPR_KRUN_CONNECT_DIR "/";
+  if (path == NULL || strncmp (path, prefix, strlen (prefix)) != 0)
+    return crun_make_error (err, EINVAL, "krun vsock path must be a direct child of `%s`", directory);
+
+  name = path + strlen (prefix);
+  if (! libkrun_valid_socket_name (name) || strchr (name, '/') != NULL || strlen (path) >= sizeof (((struct sockaddr_un *) 0)->sun_path))
+    return crun_make_error (err, EINVAL, "invalid krun vsock socket name `%s`", name);
+
+  runfd = open (SPR_KRUN_RUN_DIR, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (UNLIKELY (runfd < 0))
+    return crun_make_error (err, errno, "open trusted runtime directory");
+  if (fstat (runfd, &run_st) < 0)
+    return crun_make_error (err, errno, "inspect trusted runtime directory");
+  if (! S_ISDIR (run_st.st_mode) || run_st.st_uid != 0 || (run_st.st_mode & (S_IWGRP | S_IWOTH)) != 0)
+    return crun_make_error (err, EPERM, "`%s` must be a root-owned directory not writable by group or other", SPR_KRUN_RUN_DIR);
+
+  rootfd = openat (runfd, "spr-krun", O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (UNLIKELY (rootfd < 0))
+    return crun_make_error (err, errno, "open trusted krun socket root");
+  if (fstat (rootfd, &root_st) < 0)
+    return crun_make_error (err, errno, "inspect trusted krun socket root");
+  if (! S_ISDIR (root_st.st_mode) || root_st.st_uid != 0 || (root_st.st_mode & (S_IWGRP | S_IWOTH)) != 0)
+    return crun_make_error (err, EPERM, "`%s` must be a root-owned directory not writable by group or other", SPR_KRUN_SOCKET_ROOT);
+
+  dirfd = openat (rootfd, directory_name, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (UNLIKELY (dirfd < 0))
+    return crun_make_error (err, errno, "open trusted krun socket directory");
+  if (fstat (dirfd, &dir_st) < 0)
+    return crun_make_error (err, errno, "inspect trusted krun socket directory");
+  if (! S_ISDIR (dir_st.st_mode) || dir_st.st_uid != 0 || (dir_st.st_mode & (S_IWGRP | S_IWOTH)) != 0)
+    return crun_make_error (err, EPERM, "`%s` must be a root-owned directory not writable by group or other", directory);
+
+  ret = fstatat (dirfd, name, &socket_st, AT_SYMLINK_NOFOLLOW);
+  if (ret < 0)
+    {
+      if (errno == ENOENT && listen)
+        return 0;
+      return crun_make_error (err, errno, "inspect krun vsock UNIX socket `%s`", path);
+    }
+
+  if (listen)
+    return crun_make_error (err, EEXIST, "krun vsock UNIX socket `%s` already exists", path);
+
+  if (! S_ISSOCK (socket_st.st_mode) || socket_st.st_uid != 0)
+    return crun_make_error (err, EPERM, "krun vsock endpoint `%s` must be a root-owned UNIX socket", path);
+
+  return 0;
+}
