+static bool
+libkrun_valid_ifname (const char *name)
+{
+  size_t len;
+
+  if (name == NULL)
+    return false;
+
+  len = strlen (name);
+  if (len == 0 || len >= IFNAMSIZ)
+    return false;
+
+  for (size_t i = 0; i < len; i++)
+    if (! isalnum ((unsigned char) name[i]) && name[i] != '_' && name[i] != '-' && name[i] != '.')
+      return false;
+
+  return true;
+}
+
+/* At start time Docker has populated the private network namespace, but the
+ * krun TAP and bridge do not exist yet. Discover, rather than accept, the
+ * single Docker uplink so no policy or annotation can select another link. */
+static int
+libkrun_find_uplink (const char *tap_name, char **uplink_name, libcrun_error_t *err)
+{
+  struct if_nameindex *interfaces;
+  struct if_nameindex *interface;
+  size_t candidates = 0;
+
+  *uplink_name = NULL;
+
+  interfaces = if_nameindex ();
+  if (interfaces == NULL)
+    return crun_make_error (err, errno, "enumerate krun network interfaces");
+
+  for (interface = interfaces; interface->if_index != 0 && interface->if_name != NULL; interface++)
+    {
+      if (strcmp (interface->if_name, "lo") == 0 || strcmp (interface->if_name, "krunbr0") == 0
+          || strcmp (interface->if_name, tap_name) == 0)
+        continue;
+      candidates++;
+      if (candidates == 1)
+        *uplink_name = xstrdup (interface->if_name);
+    }
+  if_freenameindex (interfaces);
+
+  if (candidates != 1)
+    {
+      free (*uplink_name);
+      *uplink_name = NULL;
+      return crun_make_error (err, EINVAL,
+                              "krun TAP networking requires exactly one non-loopback interface (found %zu)",
+                              candidates);
+    }
+  return 0;
+}
+
+/* Return one for an existing runtime-owned interface, zero if it does not
+ * exist, and an error for an unowned or concurrently replaced interface. */
+static int
+libkrun_owned_interface (const char *name, const char *kind, libcrun_error_t *err)
+{
+  char ifalias_path[sizeof ("/sys/class/net//ifalias") + IFNAMSIZ];
+  char ifalias[64];
+  unsigned int index_before;
+  unsigned int index_after;
+  ssize_t ifalias_len;
+  cleanup_close int ifalias_fd = -1;
+  int ret;
+
+  index_before = if_nametoindex (name);
+  if (index_before == 0)
+    return 0;
+
+  ret = snprintf (ifalias_path, sizeof (ifalias_path), "/sys/class/net/%s/ifalias", name);
+  if (UNLIKELY (ret < 0 || (size_t) ret >= sizeof (ifalias_path)))
+    return crun_make_error (err, EINVAL, "could not construct krun %s ownership path", kind);
+
+  ifalias_fd = open (ifalias_path, O_RDONLY | O_CLOEXEC);
+  if (UNLIKELY (ifalias_fd < 0))
+    return crun_make_error (err, EEXIST, "%s `%s` already exists and is not owned by the SPR krun runtime", kind, name);
+
+  ifalias_len = TEMP_FAILURE_RETRY (read (ifalias_fd, ifalias, sizeof (ifalias) - 1));
+  if (UNLIKELY (ifalias_len < 0))
+    return crun_make_error (err, errno, "read krun %s ownership marker", kind);
+  while (ifalias_len > 0 && (ifalias[ifalias_len - 1] == '\n' || ifalias[ifalias_len - 1] == '\r'))
+    ifalias_len--;
+  ifalias[ifalias_len] = '\0';
+
+  index_after = if_nametoindex (name);
+  if (index_after != index_before)
+    return crun_make_error (err, EAGAIN, "krun %s `%s` changed during ownership validation", kind, name);
+  if (strcmp (ifalias, "spr-krun-runtime") != 0)
+    return crun_make_error (err, EEXIST, "%s `%s` already exists and is not owned by the SPR krun runtime", kind, name);
+
+  return 1;
+}
