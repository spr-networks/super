+static bool
+libkrun_valid_socket_name (const char *name)
+{
+  size_t len;
+
+  if (name == NULL || ! isalnum ((unsigned char) name[0]))
+    return false;
+
+  len = strlen (name);
+  if (len <= strlen (".sock") || strcmp (name + len - strlen (".sock"), ".sock") != 0)
+    return false;
+
+  for (size_t i = 1; i < len; i++)
+    if (! isalnum ((unsigned char) name[i]) && name[i] != '_' && name[i] != '-' && name[i] != '.')
+      return false;
+
+  return true;
+}
