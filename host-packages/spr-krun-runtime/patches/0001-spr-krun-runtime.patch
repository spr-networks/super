+static int
+libkrun_prepare_tap_config (void *cookie, libcrun_container_t *container, libcrun_error_t *err)
+{
+  struct krun_config *kconf = (struct krun_config *) cookie;
+  runtime_spec_schema_config_schema *def = container->container_def;
+  const char *tap_name;
+
+  tap_name = libkrun_string_configuration (kconf->config_tree, "tap_name");
+  if (tap_name == NULL)
+    return 0;
+
+  if (! libkrun_has_network_namespace (def))
+    return crun_make_error (err, EINVAL, "krun TAP networking requires a private OCI network namespace");
+  if (! libkrun_valid_ifname (tap_name) || strcmp (tap_name, "lo") == 0 || strcmp (tap_name, "krunbr0") == 0)
+    return crun_make_error (err, EINVAL, "invalid or reserved krun TAP interface name");
+
+  kconf->use_tap = true;
+  return 0;
+}
