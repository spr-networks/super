+  add_tap[4] = (char *) tap_name;
+  tag_tap[4] = (char *) tap_name;
+  attach_tap[4] = (char *) tap_name;
+  attach_uplink[4] = (char *) uplink_name;
+  flush_addr[4] = (char *) uplink_name;
+  flush_addr6[5] = (char *) uplink_name;
+  flush_route[4] = (char *) uplink_name;
