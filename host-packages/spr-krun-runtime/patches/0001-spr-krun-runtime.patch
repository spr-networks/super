+static int
+libkrun_check_trusted_directory (int fd, const char *path, mode_t forbidden_mode, libcrun_error_t *err)
+{
+  struct stat st;
+
+  if (fstat (fd, &st) < 0)
+    return crun_make_error (err, errno, "inspect trusted directory `%s`", path);
+  if (! S_ISDIR (st.st_mode) || st.st_uid != 0 || (st.st_mode & forbidden_mode) != 0)
+    return crun_make_error (err, EPERM, "`%s` is not a secure root-owned directory", path);
+  return 0;
+}
