+static int
+libkrun_setup_tap (struct krun_config *kconf, libcrun_error_t *err)
+{
+  const char *tap_name;
+  cleanup_free char *uplink_name = NULL;
+  char *delete_tap[] = { (char *) "ip", (char *) "tuntap", (char *) "del", (char *) "dev", NULL, (char *) "mode", (char *) "tap", NULL };
+  char *add_tap[] = { (char *) "ip", (char *) "tuntap", (char *) "add", (char *) "dev", NULL, (char *) "mode", (char *) "tap", NULL };
+  char *tag_tap[] = { (char *) "ip", (char *) "link", (char *) "set", (char *) "dev", NULL, (char *) "alias", (char *) "spr-krun-runtime", NULL };
+  char *add_bridge[] = { (char *) "ip", (char *) "link", (char *) "add", (char *) "name", (char *) "krunbr0", (char *) "type", (char *) "bridge", NULL };
+  char *delete_bridge[] = { (char *) "ip", (char *) "link", (char *) "del", (char *) "dev", (char *) "krunbr0", (char *) "type", (char *) "bridge", NULL };
+  char *tag_bridge[] = { (char *) "ip", (char *) "link", (char *) "set", (char *) "dev", (char *) "krunbr0", (char *) "alias", (char *) "spr-krun-runtime", NULL };
+  char *attach_tap[] = { (char *) "ip", (char *) "link", (char *) "set", (char *) "dev", NULL, (char *) "master", (char *) "krunbr0", NULL };
+  char *attach_uplink[] = { (char *) "ip", (char *) "link", (char *) "set", (char *) "dev", NULL, (char *) "master", (char *) "krunbr0", NULL };
+  char *flush_addr[] = { (char *) "ip", (char *) "addr", (char *) "flush", (char *) "dev", NULL, NULL };
+  char *flush_addr6[] = { (char *) "ip", (char *) "-6", (char *) "addr", (char *) "flush", (char *) "dev", NULL, NULL };
+  char *flush_route[] = { (char *) "ip", (char *) "route", (char *) "flush", (char *) "dev", NULL, NULL };
+  char *flush_route6[] = { (char *) "ip", (char *) "-6", (char *) "route", (char *) "flush", (char *) "dev", NULL, NULL };
+  char *up_tap[] = { (char *) "ip", (char *) "link", (char *) "set", (char *) "dev", NULL, (char *) "up", NULL };
+  char *up_uplink[] = { (char *) "ip", (char *) "link", (char *) "set", (char *) "dev", NULL, (char *) "up", NULL };
+  char *up_bridge[] = { (char *) "ip", (char *) "link", (char *) "set", (char *) "dev", (char *) "krunbr0", (char *) "up", NULL };
